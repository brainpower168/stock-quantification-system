# ==================== 数据源 API Keys ====================
# 妙想API（首选，无限制）
MX_APIKEY=your_miaoxiang_api_key_here

# 问财API（备用，每日有限）
IWENCAI_API_KEY=your_iwencai_api_key_here

# 国信API（补充，无限制）
GS_API_KEY=your_guosen_api_key_here

# ==================== AI Council API Keys ====================
# LongCat API（量化专家）
LONGCAT_API_KEY=your_longcat_api_key_here

# 讯飞星火（基本面分析师）
SPARK_API_KEY=your_spark_api_key_here

# 智谱GLM（技术分析师）
ZHIPU_API_KEY=your_zhipu_api_key_here

# ==================== 交易接口 ====================
# 国信iQuant实盘交易（可选）
IQUANT_ACCOUNT=your_account_here
IQUANT_PASSWORD=your_password_here

# ==================== 消息推送 ====================
# 钉钉机器人（可选）
DINGTALK_APP_KEY=your_app_key_here
DINGTALK_APP_SECRET=your_app_secret_here
DINGTALK_USER_ID=your_user_id_here

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE=logs/quant_system.log
LOG_ROTATION=true
LOG_ROTATION_SIZE_MB=100
LOG_BACKUP_COUNT=5

# ==================== 缓存配置 ====================
CACHE_TYPE=memory  # memory / redis
CACHE_TTL=3600
REDIS_URL=redis://localhost:6379/0

# ==================== 数据库配置 ====================
DATABASE_URL=sqlite:///data/quant.db
# PostgreSQL: postgresql://user:password@localhost:5432/quant

# ==================== 风控配置 ====================
MAX_POSITION_PCT=0.20  # 单股最大仓位20%
STOP_LOSS_PCT=0.05     # 止损5%
STOP_PROFIT_PCT=0.10   # 止盈10%
